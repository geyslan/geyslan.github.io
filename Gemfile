source "https://rubygems.org"

# Lightweight local preview stack. The deployed site is built by GitHub
# Pages; this just renders the same Markdown/Liquid/CSS locally.
gem "jekyll", "~> 4.3"

group :jekyll_plugins do
  gem "jemoji"
end

# WEBrick is no longer a default gem from Ruby 3.0 onward; needed by
# `jekyll serve`.
gem "webrick", "~> 1.8"
